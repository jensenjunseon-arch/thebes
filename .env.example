# Supabase — create a project at supabase.com, then copy these from
# Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic — used by both the tutor (Sonnet) and the scorer (Sonnet).
# Scorer cost is the dominant variable; monitor it from day 1.
ANTHROPIC_API_KEY=

# Toss Payments — D2C billing for the Korean market. M4 milestone.
TOSS_CLIENT_KEY=
TOSS_SECRET_KEY=
