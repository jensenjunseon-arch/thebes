# Supabase — create a project at supabase.com, then copy these from
# Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic — used by both the tutor (Sonnet) and the scorer (Sonnet).
# Scorer cost is the dominant variable; monitor it from day 1.
ANTHROPIC_API_KEY=

# Toss Payments — monthly subscription (정기결제/빌링).
# Get TEST keys from https://developers.tosspayments.com (내 개발정보 → 테스트 키).
# Client key is public (browser); secret key is server-only — never commit a real one.
NEXT_PUBLIC_TOSS_CLIENT_KEY=test_ck_xxxxxxxxxxxxxxxxxxxx
TOSS_SECRET_KEY=test_sk_xxxxxxxxxxxxxxxxxxxx

# Recurring-charge cron (POST /api/billing/charge-due). Set any long random string;
# on Vercel, set the same value as the project's CRON_SECRET so Cron can call it.
CRON_SECRET=
